# ==============================================================================
# [SAMPLE] MiniMAGUX Network Traffic Monitor Configuration File
# ==============================================================================
#
# 이 파일은 collector.cfg 설정 파일의 샘플 템플릿입니다.
# 실환경에 적용하시려면 이 파일을 'collector.cfg'로 복사하여 알맞게 편집하십시오.
# (명령어: cp collector.cfg.sample collector.cfg)
#

# ------------------------------------------------------------------------------
# 1. CSV 로그 저장 경로 설정 (CSV Storage Directory)
# ------------------------------------------------------------------------------
csv_dir = ./csv_logs

# ------------------------------------------------------------------------------
# 2. 패킷 수집 대상 네트워크 카드 인터페이스 (Network Interface)
# ------------------------------------------------------------------------------
# 사용 중인 리눅스 배포판 및 환경에 맞는 이더넷 장치명을 입력하십시오.
# (확인 방법: ip link)
interface = eth0

# ------------------------------------------------------------------------------
# 3. Manticore Search 엔진 실시간 연동 여부 (Database Integration)
# ------------------------------------------------------------------------------
# 실시간 대시보드 웹 UI를 사용하려면 true로 설정하고 Manticore 엔진을 구동하십시오.
use_manticore = true

# ------------------------------------------------------------------------------
# 4. Manticore Search 데이터베이스 접속 설정 (Database Connection Settings)
# ------------------------------------------------------------------------------
manticore_host = 127.0.0.1
manticore_port = 9306
